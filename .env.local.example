# ──────────────────────────────────────────────
# UNIQUE Platform — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ──────────────────────────────────────────────

# MongoDB Atlas connection string (get free cluster at mongodb.com/atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/unique?retryWrites=true&w=majority

# JWT secrets — generate random strings, e.g. run: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_random_64_char_string
JWT_REFRESH_SECRET=replace_with_a_DIFFERENT_random_64_char_string

# Gemini API key — free tier, get it at aistudio.google.com/app/apikey
GEMINI_API_KEY=replace_with_your_gemini_key

# Cloudflare Turnstile — free, get keys at dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=replace_with_turnstile_secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=replace_with_turnstile_site_key

# Encryption key for at-rest encryption of sensitive values (API keys, etc.)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace_with_random_32_char_string

# App URL (used for email links, certificate verification, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# SMTP credentials for password reset emails
# For Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587
# Use an App Password (not your real password) generated at:
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
